[models.default_chat]
provider = "ollama"
model = "qwen3.5:9b"
temperature = 0.7
max_output_tokens = 512

[models.fast_judge]
provider = "ollama"
model = "qwen3.5:9b"
temperature = 0.0
max_output_tokens = 256

[models.reasoning]
provider = "ollama"
model = "qwen3.5:9b"
temperature = 0.0
max_output_tokens = 1024

[ollama]
base_url = "http://localhost:11434"
timeout_seconds = 120.0
keep_alive = "10m"

[diagnostics]
mode = "warn"
warmup_models = true
