[importlinter]
root_package = iris

[importlinter:contract:contracts_are_pure]
name = contracts must not import implementation layers
type = forbidden
source_modules =
    iris.contracts
forbidden_modules =
    iris.cognitive
    iris.runtime
    iris.adapters
    iris.features
    iris.presentation
    iris.safety

[importlinter:contract:cognitive_is_pure]
name = cognitive must not import runtime, adapters, or features
type = forbidden
source_modules =
    iris.cognitive
forbidden_modules =
    iris.runtime
    iris.adapters
    iris.features

[importlinter:contract:features_do_not_import_outer_layers]
name = features must not import runtime, adapters, presentation, or safety
type = forbidden
source_modules =
    iris.features
forbidden_modules =
    iris.runtime
    iris.adapters
    iris.presentation
    iris.safety

[importlinter:contract:presentation_is_pure]
name = presentation must not import runtime, features, adapters, or safety
type = forbidden
source_modules =
    iris.presentation
forbidden_modules =
    iris.runtime
    iris.features
    iris.adapters
    iris.safety

[importlinter:contract:runtime_service_does_not_import_low_level_effects]
name = runtime service must not import low level runtime effects
type = forbidden
allow_indirect_imports = True
source_modules =
    iris.runtime.service
forbidden_modules =
    iris.runtime.state
    iris.runtime.scheduler
    iris.runtime.delivery
    iris.runtime.lifecycle
    iris.runtime.observability.events
    iris.runtime.observability.logger
    iris.runtime.observability.llm
    iris.runtime.observability.diagnostics
    iris.features
    iris.presentation
    iris.adapters
